<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <title>{{ personal.name }} - {{ title }}</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main class="page">
    <header class="header">
      <h1>{{ personal.name }}</h1>
      <h2>{{ title }}</h2>
      <p class="contact">{{ personal.location[lang] }} • {{ personal.phone }} • {{ personal.email }} • {{ personal.github }} • {{ personal.linkedin }}</p>
    </header>

    <section>
      <h3>{{ labels.professional_summary }}</h3>
      <p>{{ summary }}</p>
    </section>

    <section>
      <h3>{{ labels.professional_experience }}</h3>
      {% for job in experience %}
      <article class="item">
        <p class="headline"><strong>{{ job.company_name }}</strong> <span>| {{ job.role[lang] }} | {{ job.date_range }}</span></p>
        <p>{{ job.description[lang] }}</p>
        {% if job.bullets %}<ul>{% for bullet in job.bullets %}<li>{{ bullet[lang] }}</li>{% endfor %}</ul>{% endif %}
        <p class="tech"><strong>{{ labels.technologies }}:</strong> {{ job.technologies | join(', ') }}</p>
      </article>
      {% endfor %}
    </section>

    <section>
      <h3>{{ labels.personal_projects }}</h3>
      {% for project in projects %}
      <article class="item">
        <p class="headline"><strong>{{ project.name }}</strong></p>
        <p>{{ project.description[lang] }}</p>
        {% if project.bullets %}<ul>{% for bullet in project.bullets %}<li>{{ bullet[lang] }}</li>{% endfor %}</ul>{% endif %}
        <p class="tech"><strong>{{ labels.technologies }}:</strong> {{ project.technologies | join(', ') }}</p>
      </article>
      {% endfor %}
    </section>

    <section>
      <h3>{{ labels.education }}</h3>
      <ul class="compact">{% for item in education %}<li>{{ item[lang] }}</li>{% endfor %}</ul>
    </section>

    <section>
      <h3>{{ labels.technical_skills }}</h3>
      <div class="skills">{% for group, values in skills.items() %}<p><strong>{{ group }}:</strong> {{ values | join(', ') }}</p>{% endfor %}</div>
    </section>

    <section>
      <h3>{{ labels.certifications }}</h3>
      <ul class="compact">{% for item in certifications %}<li>{{ item[lang] }}</li>{% endfor %}</ul>
    </section>
  </main>
</body>
</html>
