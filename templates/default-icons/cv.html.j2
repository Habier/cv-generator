<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <title>{{ personal.name }} - {{ title }}</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main class="page">
    <header class="hero">
      <h1>{{ personal.name }}</h1>
      <p class="headline">{{ title }}</p>
      <address class="contact" aria-label="Contact information">
        <div class="contact-line">
          <span>
            <svg class="contact-icon" viewBox="0 0 384 512" aria-hidden="true" focusable="false">
              <path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z" />
            </svg>{{ personal.location[lang] }}
          </span>
          <span>
            <svg class="contact-icon" viewBox="0 0 512 512" aria-hidden="true" focusable="false">
              <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z" />
            </svg>{{ personal.phone }}
          </span>
          <span>
            <a class="contact-link" href="mailto:{{ personal.email }}">
              <svg class="contact-icon" viewBox="0 0 512 512" aria-hidden="true" focusable="false">
                <path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4l217.6 163.2c11.4 8.5 27 8.5 38.4 0l217.6-163.2c12.1-9.1 19.2-23.3 19.2-38.4 0-26.5-21.5-48-48-48H48zM0 176v208c0 35.3 28.7 64 64 64h384c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z" />
              </svg>{{ personal.email }}
            </a>
          </span>
        </div>
        <div class="contact-line contact-line-social">
          <span>
            <a class="contact-link" href="{{ personal.github }}">
              <svg class="contact-icon" viewBox="0 0 496 512" aria-hidden="true" focusable="false">
                <path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8z" />
              </svg>{{ personal.github | replace('https://', '') | replace('http://', '') }}
            </a>
          </span>
          <span>
            <a class="contact-link" href="{{ personal.linkedin }}">
              <svg class="contact-icon" viewBox="0 0 448 512" aria-hidden="true" focusable="false">
                <path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3C448 46.5 433.6 32 416 32zM135.4 416H69V202.2h66.5V416h-.1zM102.2 173c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z" />
              </svg>{{ personal.linkedin | replace('https://', '') | replace('http://', '') }}
            </a>
          </span>
        </div>
      </address>
    </header>

    <section class="section" aria-labelledby="summary-heading">
      <h2 id="summary-heading">{{ labels.professional_summary }}</h2>
      <p>{{ summary }}</p>
    </section>

    <section class="section" aria-labelledby="experience-heading">
      <h2 id="experience-heading">{{ labels.professional_experience }}</h2>
      {% for job in experience %}
      <article class="item">
        <header class="item-header">
          <div>
            <h3>{{ job.company_name }} <span class="role-group"><span class="title-separator">-</span> <span class="role">{{ job.role[lang] }}</span></span></h3>
          </div>
          <p class="date-range">{{ job.date_range }}</p>
        </header>
        <p>{{ job.description[lang] }}</p>
        {% if job.bullets %}
        <div class="text-list" role="list">
          {% for bullet in job.bullets %}
          <div class="text-list-item" role="listitem"><svg class="list-marker" viewBox="0 0 4 4" aria-hidden="true" focusable="false"><circle cx="2" cy="2" r="1.7" /></svg><span>{{ bullet[lang] }}</span></div>
          {% endfor %}
        </div>
        {% endif %}
        <p class="tech"><strong>{{ labels.technologies }}:</strong> {{ job.technologies | join(', ') }}</p>
      </article>
      {% endfor %}
    </section>

    <section class="section" aria-labelledby="projects-heading">
      <h2 id="projects-heading">{{ labels.personal_projects }}</h2>
      {% for project in projects %}
      <article class="item">
        <h3>{% if project.url %}<a href="{{ project.url }}">{{ project.name }}</a>{% else %}{{ project.name }}{% endif %}</h3>
        <p>{{ project.description[lang] }}</p>
        {% if project.bullets %}
        <div class="text-list" role="list">
          {% for bullet in project.bullets %}
          <div class="text-list-item" role="listitem"><svg class="list-marker" viewBox="0 0 4 4" aria-hidden="true" focusable="false"><circle cx="2" cy="2" r="1.7" /></svg><span>{{ bullet[lang] }}</span></div>
          {% endfor %}
        </div>
        {% endif %}
        <p class="tech"><strong>{{ labels.technologies }}:</strong> {{ project.technologies | join(', ') }}</p>
      </article>
      {% endfor %}
    </section>

    <section class="section compact-section" aria-labelledby="education-heading">
      <h2 id="education-heading">{{ labels.education }}</h2>
      <div class="text-list simple-list" role="list">
        {% for item in education %}
        <div class="text-list-item" role="listitem"><svg class="list-marker" viewBox="0 0 4 4" aria-hidden="true" focusable="false"><circle cx="2" cy="2" r="1.7" /></svg><span>{{ item[lang] }}</span></div>
        {% endfor %}
      </div>
    </section>

    {% if languages %}
    <section class="section compact-section" aria-labelledby="languages-heading">
      <h2 id="languages-heading">{{ labels.languages }}</h2>
      <div class="text-list simple-list" role="list">
        {% for item in languages %}
        <div class="text-list-item" role="listitem"><svg class="list-marker" viewBox="0 0 4 4" aria-hidden="true" focusable="false"><circle cx="2" cy="2" r="1.7" /></svg><span><strong>{{ item.name[lang] }}:</strong> {{ item.level[lang] }}</span></div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="section" aria-labelledby="skills-heading">
      <h2 id="skills-heading">{{ labels.technical_skills }}</h2>
      <div class="skills">
        {% for group, values in skills.items() %}
        <p><strong>{{ group }}:</strong> {{ values | join(', ') }}</p>
        {% endfor %}
      </div>
    </section>

    <section class="section compact-section" aria-labelledby="certifications-heading">
      <h2 id="certifications-heading">{{ labels.certifications }}</h2>
      <div class="text-list simple-list" role="list">
        {% for item in certifications %}
        <div class="text-list-item" role="listitem"><svg class="list-marker" viewBox="0 0 4 4" aria-hidden="true" focusable="false"><circle cx="2" cy="2" r="1.7" /></svg><span>{{ item[lang] }}</span></div>
        {% endfor %}
      </div>
    </section>
  </main>
</body>
</html>
